DATABASE_URL=sqlite+aiosqlite:///./localkart.db
SECRET_KEY=localkart-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
AI_SERVICE_URL=http://localhost:8001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# PhonePe Payment Gateway (Standard Checkout, PG API v2)
# Get these from https://business.phonepe.com after UAT/sandbox onboarding.
# Leave PHONEPE_ENV=SANDBOX until you're ready to go live with real money.
PHONEPE_CLIENT_ID=
PHONEPE_CLIENT_SECRET=
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=SANDBOX
# Username/password YOU choose and configure on the PhonePe dashboard
# for the webhook URL below -- used to verify callbacks are genuinely
# from PhonePe.
PHONEPE_CALLBACK_USERNAME=localkart
PHONEPE_CALLBACK_PASSWORD=change-this-password
# Must be publicly reachable for PhonePe to call it (use ngrok in local dev):
#   https://<your-domain>/api/v1/payments/phonepe/webhook
FRONTEND_URL=http://localhost:3000